# Production environment variables for scrapyards.io
# Copy this file to .env.production on the VPS and fill in real values.
# DO NOT commit .env.production to git.

# Postgres connection string. Password must be URL-encoded.
DATABASE_URL=postgresql://scrapyards_app:<urlencoded-password>@localhost:5433/scrapyards

# Mapbox public token (safe to expose, scoped to scrapyards.io referrer).
NEXT_PUBLIC_MAPBOX_TOKEN=pk.<your-mapbox-public-token>

NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://scrapyards.io
